void solve(int i , string s , string temp , vector<string>& ans){
       if(i == s.size()){
           ans.push_back(temp);
           return;
       }
       
       solve(i+1 , s , temp + s[i] , ans);
       solve(i+1 , s , temp , ans);
   }
  
    vector<string> AllPossibleStrings(string s) {
        vector<string> ans;
        solve(0 , s , "",ans);
        
        sort(ans.begin() , ans.end());
        return ans;
    }
